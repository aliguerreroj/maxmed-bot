{
  "name": "maxmed-bot",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "Customer-facing price-quote chatbot for MAXMED Distributors (diabetic supplies buyer). Grounded pricing: code computes, LLM only phrases.",
  "engines": {
    "node": ">=22"
  },
  "scripts": {
    "import": "tsx src/import.ts",
    "dev": "tsx watch src/bot/index.ts",
    "start": "tsx src/bot/index.ts",
    "test": "vitest run",
    "test:watch": "vitest",
    "db:generate": "prisma generate",
    "db:migrate": "prisma migrate dev",
    "db:studio": "prisma studio",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.30.1",
    "@prisma/client": "^5.22.0",
    "dotenv": "^16.4.5",
    "exceljs": "^4.4.0",
    "grammy": "^1.30.0",
    "pdfkit": "^0.15.1"
  },
  "devDependencies": {
    "@types/node": "^22.9.0",
    "@types/pdfkit": "^0.13.5",
    "prisma": "^5.22.0",
    "tsx": "^4.19.2",
    "typescript": "^5.6.3",
    "vitest": "^2.1.5"
  }
}
